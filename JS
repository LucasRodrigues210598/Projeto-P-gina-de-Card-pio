const COMBOS = [
  { name: "Combo Casal",   items: "1 pizza média\n1 pizza doce pequena\n2 refrigerantes lata",     price: 89,  eco: "Economize até R$ 18" },
  { name: "Combo Família", items: "2 pizzas grandes\n1 pizza doce média\n2L refrigerante",          price: 149, eco: "Economize até R$ 30" },
