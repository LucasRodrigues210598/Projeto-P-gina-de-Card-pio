];

const SIZES = { P: "Pequena", M: "Média", G: "Grande", F: "Família", U: "Unid." };

// ── Estado ─────────────────────────────────────────────────────
let cart = [];
let selectedSizes = {};

// ── Badges ─────────────────────────────────────────────────────
function badgeHTML(b) {
  if (b === "top") return '<span class="badge badge-top">Top</span>';
  if (b === "new") return '<span class="badge badge-new">Novo</span>';
  if (b === "veg") return '<span class="badge badge-veg">Veg</span>';
  return "";
}

// ── Montar card de pizza ───────────────────────────────────────
function buildPizzaCard(item, cat, idx) {
  const sizeKeys = Object.keys(item.prices);
  const defSize  = sizeKeys[1] || sizeKeys[0];
  const key      = cat + "-" + idx;

  if (!selectedSizes[key]) selectedSizes[key] = defSize;

  const sizeHTML   = sizeKeys.map(s =>
    `<button class="size-btn ${selectedSizes[key] === s ? "selected" : ""}"
      onclick="selectSize(event,'${key}','${s}',${JSON.stringify(item.prices)},this)">
      ${SIZES[s] || s}
    </button>`
  ).join("");

  const badgesHTML = item.badges.map(badgeHTML).join("");
  const price      = item.prices[selectedSizes[key]];

  return `
  <div class="pizza-card" id="card-${key}">
    <div class="pizza-card-top">
      ${item.badges.length ? `<div class="pizza-badge-row">${badgesHTML}</div>` : ""}
      <div class="pizza-name">${item.name}</div>
      <div class="pizza-desc">${item.desc}</div>
      ${!item.single ? `<div class="pizza-sizes">${sizeHTML}</div>` : ""}
    </div>
    <div class="pizza-card-bottom">
      <div class="pizza-price" id="price-${key}">R$ ${price}</div>
      <button class="add-btn" onclick="addToCart('${key}','${cat}',${idx})">+ Adicionar</button>
    </div>
  </div>`;
}

// ── Selecionar tamanho ─────────────────────────────────────────
function selectSize(e, key, size, prices, btn) {
  e.stopPropagation();
  selectedSizes[key] = size;
  const card = document.getElementById("card-" + key);
  card.querySelectorAll(".size-btn").forEach(b => b.classList.remove("selected"));
  btn.classList.add("selected");
  document.getElementById("price-" + key).textContent = "R$ " + prices[size];
}

// ── Adicionar ao carrinho ──────────────────────────────────────
function addToCart(key, cat, idx) {
  const item  = cat === "bebidas" ? MENU.bebidas[idx] : MENU[cat][idx];
  const size  = selectedSizes[key] || Object.keys(item.prices)[0];
  const price = item.prices[size];
  const label = item.single ? item.name : `${item.name} · ${SIZES[size] || size}`;

  cart.push({ key: Date.now(), name: item.name, size: item.single ? "" : (SIZES[size] || size), price, label });
  renderCart();

  const btn = document.querySelector(`#card-${key} .add-btn`);
  btn.textContent = "✓ Adicionado";
  btn.style.background = "#2d6a2d";
  setTimeout(() => { btn.textContent = "+ Adicionar"; btn.style.background = ""; }, 1200);
}

function addComboToCart(idx) {
  const c = COMBOS[idx];
  cart.push({ key: Date.now(), name: c.name, size: "", price: c.price, label: c.name });
  renderCart();
}

function removeFromCart(key) {
  cart = cart.filter(i => i.key !== key);
  renderCart();
}

// ── Renderizar carrinho ────────────────────────────────────────
function renderCart() {
  const empty  = document.getElementById("cart-empty");
  const items  = document.getElementById("cart-items");
  const footer = document.getElementById("cart-footer");
  const badge  = document.getElementById("cart-count-badge");

  if (cart.length === 0) {
    empty.style.display  = "block";
    items.style.display  = "none";
    footer.style.display = "none";
    badge.style.display  = "none";
    document.getElementById("confirm-box").classList.remove("show");
    return;
  }

  empty.style.display  = "none";
  items.style.display  = "block";
  footer.style.display = "flex";
  badge.style.display  = "inline-flex";
  badge.textContent    = cart.length;

  const total = cart.reduce((s, i) => s + i.price, 0);
  document.getElementById("cart-total-val").textContent = "R$ " + total;

  items.innerHTML = cart.map(i => `
    <div class="cart-item">
      <div>
        <div class="cart-item-name">${i.name}</div>
        ${i.size ? `<div class="cart-item-size">${i.size}</div>` : ""}
      </div>
      <div class="cart-item-right">
        <div class="cart-item-price">R$ ${i.price}</div>
        <button class="cart-remove" onclick="removeFromCart(${i.key})">✕</button>
      </div>
    </div>`).join("");
}

// ── Checkout ───────────────────────────────────────────────────
function checkout() {
  const total = cart.reduce((s, i) => s + i.price, 0);
  const list  = cart.map(i => `• ${i.label} — R$ ${i.price}`).join("\n");
  document.getElementById("confirm-desc").innerHTML =
    `<pre style="text-align:left;font-family:Arial,sans-serif;font-size:12px;color:#A07848;background:#0e0600;border-radius:8px;padding:12px;margin-bottom:10px">${list}\n\nTotal: R$ ${total}</pre>Confirme e envie seu pedido pelo WhatsApp!`;
  document.getElementById("confirm-box").classList.add("show");
}

function sendWpp() {
  const total = cart.reduce((s, i) => s + i.price, 0);
  const msg   = encodeURIComponent(
    "Olá! Gostaria de fazer um pedido:\n\n" +
    cart.map(i => `• ${i.label} — R$ ${i.price}`).join("\n") +
    "\n\nTotal: R$ " + total
  );
  // ⚠️ Substitua pelo número real da pizzaria
  window.open("https://wa.me/5544999990000?text=" + msg, "_blank");
}

// ── Navegação ──────────────────────────────────────────────────
function showTab(tab, btn) {
  document.querySelectorAll(".section").forEach(s => s.classList.remove("active"));
  document.querySelectorAll(".nav-btn").forEach(b => b.classList.remove("active"));
  document.getElementById("tab-" + tab).classList.add("active");
  btn.classList.add("active");
}

// ── Montar combos ──────────────────────────────────────────────
function buildCombos() {
  document.getElementById("grid-combos").innerHTML = COMBOS.map((c, i) => `
    <div class="combo-card">
      <div class="combo-name">${c.name}</div>
      <div class="combo-items">${c.items.replace(/\n/g, "<br>")}</div>
      <div class="combo-bottom">
        <div>
          <div class="combo-price">R$ ${c.price}</div>
          <div class="combo-eco">${c.eco}</div>
        </div>
        <button class="add-btn" onclick="addComboToCart(${i})">+ Adicionar</button>
      </div>
    </div>`).join("");
}

// ── Inicializar ────────────────────────────────────────────────
["tradicionais", "especiais", "doces", "bebidas"].forEach(cat => {
  const el = document.getElementById("grid-" + cat);
  if (el) el.innerHTML = MENU[cat].map((item, i) => buildPizzaCard(item, cat, i)).join("");
});
buildCombos();
